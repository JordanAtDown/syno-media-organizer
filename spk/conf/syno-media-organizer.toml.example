# syno-media-organizer configuration
# Edit this file and restart the service after any change.

# How often to scan input folders for new files, in seconds (default: 30)
# poll_interval_secs = 30

[[folders]]
input    = "/volume1/inbox/camera"
output   = "/volume1/Phototheque"
pattern  = "{year}/{month}/{year}-{month}-{day}_{hour}{min}{sec}_{stem}{ext}"
recursive   = true
on_conflict = "rename"
extensions  = ["jpg", "jpeg", "png", "heic", "mp4", "mov", "avi", "mkv"]

# [[folders]]
# input    = "/volume1/inbox/phone"
# output   = "/volume1/Phototheque"
# on_conflict = "skip"
# extensions = ["jpg", "jpeg", "heic", "mp4"]
