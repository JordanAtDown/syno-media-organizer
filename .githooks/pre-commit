#!/usr/bin/env bash
# pre-commit hook: enforces code quality before each commit.
# Activate with: git config core.hooksPath .githooks
set -euo pipefail

# When running on Windows (Git Bash), re-invoke this hook through WSL
# where Rust tooling (cargo, clippy, rustfmt) is installed.
if [[ -z "${WSL_DISTRO_NAME:-}" ]] && command -v wsl.exe &>/dev/null; then
    REPO_WIN=$(git rev-parse --show-toplevel)
    REPO_WSL=$(wsl wslpath "$REPO_WIN")
    wsl bash -c "cd '$REPO_WSL' && .githooks/pre-commit"
    exit $?
fi

# In WSL, non-interactive shells don't source .bashrc — load cargo manually.
export PATH="$HOME/.cargo/bin:$PATH"

echo "[pre-commit] Checking format..."
cargo fmt --check

echo "[pre-commit] Running clippy..."
cargo clippy --all-targets -- -D warnings

echo "[pre-commit] Running unit tests..."
cargo test --lib

echo "[pre-commit] All checks passed."
