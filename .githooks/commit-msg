#!/usr/bin/env bash
# commit-msg hook: validates Conventional Commits format.
# Activate with: git config core.hooksPath .githooks
set -euo pipefail

COMMIT_MSG_FILE="$1"

# When running on Windows (Git Bash), re-invoke this hook through WSL.
if [[ -z "${WSL_DISTRO_NAME:-}" ]] && command -v wsl.exe &>/dev/null; then
    REPO_WIN=$(git rev-parse --show-toplevel)
    REPO_WSL=$(wsl wslpath "$REPO_WIN")
    wsl bash -c "cd '$REPO_WSL' && .githooks/commit-msg '$COMMIT_MSG_FILE'"
    exit $?
fi

COMMIT_MSG="$(cat "${COMMIT_MSG_FILE}")"

# Allow merge commits and revert commits
if echo "${COMMIT_MSG}" | grep -qE '^(Merge|Revert) '; then
    exit 0
fi

PATTERN='^(feat|fix|chore|docs|style|refactor|perf|test|build|ci|revert)(\(.+\))?!?: .{1,72}'

if ! echo "${COMMIT_MSG}" | grep -qE "${PATTERN}"; then
    echo ""
    echo "ERROR: Commit message does not follow Conventional Commits format."
    echo ""
    echo "  Expected: <type>(<scope>): <subject>"
    echo "  Example:  feat(watcher): add debounced inotify support"
    echo ""
    echo "  Valid types: feat fix chore docs style refactor perf test build ci revert"
    echo "  Subject: imperative mood, ≤72 characters, no trailing period"
    echo ""
    echo "  See .github/COMMIT_CONVENTION.md for details."
    echo ""
    exit 1
fi

exit 0
